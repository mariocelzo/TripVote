ENV=development

# Supabase (DB + storage + realtime — auth gestita da Clerk)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_WEBHOOK_SECRET=xxxxx

# Clerk — auth provider (JWT RS256 via JWKS)
# Clerk Dashboard → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL=https://xxxx.clerk.accounts.dev/.well-known/jwks.json

# Redis (Upstash)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# SendGrid
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@tripvote.me

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Match thresholds
MATCH_QUORUM_THRESHOLD=0.5
MATCH_SCORE_THRESHOLD=0.7
MATCH_YES_WEIGHT=1.0
MATCH_MAYBE_WEIGHT=0.5
MATCH_NO_WEIGHT=0.0

# Internal secrets
CRON_SECRET=change-me-in-production
